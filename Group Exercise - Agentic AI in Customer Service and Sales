        "def route_by_intent(state: ChatState):\n",
        "    if state[\"intent\"] == \"order_status\":\n",
        "        return \"order_status_agent\"\n",
        "    elif state[\"intent\"] == \"refund_policy\":\n",
        "        return \"refund_policy_agent\"\n",
        "    elif state[\"intent\"] == \"product_recommendation\":\n",
        "        return \"product_recommendation_agent\"\n",
        "    else:\n",
        "        return \"fallback_agent\""
      ],
      "metadata": {
        "id": "mt1dw0hlUrKD"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "builder.add_conditional_edges(\n",
        "    \"router\",\n",
        "    route_by_intent,\n",
        "    {\n",
        "        \"order_status_agent\": \"order_status_agent\",\n",
        "        \"refund_policy_agent\": \"refund_policy_agent\",\n",
        "        \"product_recommendation_agent\": \"product_recommendation_agent\",\n",
        "        \"fallback_agent\": \"fallback_agent\",\n",
        "    }\n",
        ")\n",
        "\n",
        "builder.add_edge(\"order_status_agent\", END)\n",
        "builder.add_edge(\"refund_policy_agent\", END)\n",
        "builder.add_edge(\"product_recommendation_agent\", END)\n",
        "builder.add_edge(\"fallback_agent\", END)"
